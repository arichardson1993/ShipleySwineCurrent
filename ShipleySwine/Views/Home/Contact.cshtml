<script type="text/javascript">

    $(function () {

        $("#emailForm").validate({
            rules: {
                fullname: "required"
            },
            submitHandler: function (form) {
                form.submit();
            }
        });

    });

    toastr.options = {
        "closeButton": false,
        "debug": false,
        "newestOnTop": false,
        "progressBar": false,
        "positionClass": "toast-bottom-center",
        "preventDuplicates": false,
        "onclick": null,
        "showDuration": "300",
        "hideDuration": "1000",
        "timeOut": "10000",
        "extendedTimeOut": "1000",
        "showEasing": "swing",
        "hideEasing": "linear",
        "showMethod": "fadeIn",
        "hideMethod": "fadeOut"
    }



    $("#submitButton").click(function () {

        var validForm = true;
        

        console.log($("#form-name").val());
        if ($("#form-name").val() == "") {
            $("#form-name").css("border-bottom-color", "red");
            $("#errorMessage").html("Please correct the errors!");
            $("#errorMessage").show();
            validForm = false;
        } else
        {
            $("#form-name").css("border-bottom-color", "#ced4da");
        }

        if ($("#form-email").val() == "") {
            $("#form-email").css("border-bottom-color", "red");
            $("#errorMessage").html("Please correct the errors!");
            $("#errorMessage").show();
            validForm = false;
        } else
        {
            $("#form-email").css("border-bottom-color", "#ced4da");
        }
        if ($("#form-phone").val() == "") {
            $("#form-phone").css("border-bottom-color", "red");
            $("#errorMessage").html("Please correct the errors!");
            $("#errorMessage").show();
            validForm = false;
        } else
        {
            $("#form-phone").css("border-bottom-color", "#ced4da");
        }

        if ($("#form-Subject").val() == "") {
            $("#form-Subject").css("border-bottom-color", "red");
            $("#errorMessage").html("Please correct the errors!");
            $("#errorMessage").show();
            validForm = false;
        } else
        {
            $("#form-Subject").css("border-bottom-color", "#ced4da");
        }

        if ($("#form-text").val() == "") {
            $("#form-text").css("border-bottom-color", "red");
            $("#errorMessage").html("Please correct the errors!");
            $("#errorMessage").show();
            validForm = false;
        } else
        {
            $("#form-text").css("border-bottom-color", "#ced4da");
        }

        if (validForm) {
            $("#errorMessage").hide();
            $("#submitButton").prop("disabled", true);
            $("#emailSection").busyLoad("show", {

            });


            $.post('@Url.Action("Email", "Home")',
            {
                fullname: $("#form-name").val(),
                email: $("#form-email").val(),
                phone: $("#form-phone").val(),
                subject: $("#form-Subject").val(),
                comments: $("#form-text").val()
                },
                function (data, status, jqXHR) {
                    if (data == "true") {
                        toastr.success("Email Successful!");
                        $("#emailSection").busyLoad("hide", {

                        });
                        $("#form-name").val("");
                        $("#form-email").val("");
                        $("#form-phone").val("");
                        $("#form-Subject").val("");
                        $("#form-text").val("");
                        $("#submitButton").prop("disabled", false);

                    } else {
                        toastr.error("Something went wrong, please try again!");
                        console.log(data);
                        $("#emailSection").busyLoad("hide", {

                        });
                        $("#submitButton").prop("disabled", false);
                    }
            });
        }


    });
</script>