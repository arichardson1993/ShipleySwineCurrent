@model List<ShipleySwine.SellingPoint1>
@{
    ViewBag.Title = "Troubleshooting";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Troubleshooting</h2>
<table>
    <thead>
        <tr>
            <th>
                SellingpointId
            </th>
            <th>
                ID
            </th>
            <th>
                Text
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach(var item in Model)
        {
        <tr>
            <td>
                @item.SellingPoints_Id
            </td>
            <td>
                @item.ID
            </td>
            <td>
                @item.SellingPoint
            </td>
        </tr>
        }
    </tbody>
</table>


