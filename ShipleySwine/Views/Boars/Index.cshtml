@model IEnumerable<ShipleySwine.Boar>


@{
    ViewBag.Title = "Index";
    string imgURL;
    int counter = 0;
    int count2 = 0;
}

<div class="container">

    <div class="row row-centered">
        @foreach (var item in Model)
        {
            imgURL = "~/Boars/" + item.Breed + "/" + item.NameNoSpaces + "/Large/" + item.NameNoSpaces + "1.jpg";

            if (counter == 2)
            {
            @:</div>
            @:<div class="row">




                counter = 0;
            }

<div class="col-lg-6 col-md-6 col-sm-6 col-xs-6 d-flex internet-ex">
    <div class="card mb-4 border-secondary flex-fill internet-ex-int">
        <div class="card-header text-center bg-secondary text-white"><h2 class="card-title">@Html.DisplayFor(modelItem => item.Name)</h2></div>
        <div class="flex-fill internet-ex-int">
            @*col-lg-5*@
            <div style="padding-top:30px;"class="col-lg-12 col-md-12">
                <img style="height:initial; text-align:center; margin:auto; display:block;" src="@Url.Content(imgURL)" class="card-img" alt="Photo Didnt Load">
            </div>
            @*col-lg-7*@
            <div style="padding-top:20px;"class="col-lg-12 col-md-12 border-secondary">
                <div class="card-body">
                    <div>
                        <div class="text-center">
                            <h5 class="card-title">Sire: @Html.DisplayFor(modelItem => item.Sire) | Dam: @Html.DisplayFor(modelItem => item.Dam)</h5>
                        </div>
                    </div>
                    <hr />
                    <div class="listcontainer h-100">
                        @foreach (var _it in item.SellingPoints)
                        {
                            count2 = 0;
                            foreach (var _it2 in _it.SellingPoints)
                            {
                                if(count2 < 5)
                                {
                                   @: <ul>
                                   @:     <li><p class="card-text">@_it2.SellingPoint</p></li>
                                   @: </ul>
                                }
                                count2++;
                            }

                        }

                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer text-center w-100">
            <p style="margin:auto; font-size:large;">$ @Html.DisplayFor(modelItem => item.Price)</p>
        </div>
    </div>
</div>
