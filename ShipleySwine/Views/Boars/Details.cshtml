@model ShipleySwine.Boar

@{
    ViewBag.Title = "Details";
    int count = 1;
    int num = ViewBag.imagecount;
    int number = 1;
}

<head>
    <link href="~/Content/SlideShow.css" rel="stylesheet">
    <link href="~/Content/DetailsStyle.css" rel="stylesheet">
</head>

    <hr />
<div class="container">
    <!-- Slideshow container -->
    <div class="slideshow-container" style="max-height: 800px; max-width:650px;">
        <!-- Full-width images with number and caption text -->
        @foreach (var image in (IEnumerable<string>)ViewData["images"])
        {
            <div class="mySlides fadee backgroundcolor text-center" style="max-height: 650px; max-width:650px;">
                <div class="numbertext">@count / @num</div>
                <img src="@Url.Content(image)" style="width:100%; height:100%; object-fit:contain; max-width:inherit; max-height:inherit;">
            </div>
            count++;
        }

        <!-- Next and previous buttons -->
        <a class="prev" onclick="plusSlides(-1)">&#10094;</a>
        <a class="next" onclick="plusSlides(1)">&#10095;</a>
    </div>
    <br>

    <!-- The dots/circles -->
    <div style="text-align:center">


        @foreach (var image in (IEnumerable<string>)ViewData["images"])
        {

            @*<img class="dot mb-2" src="@Url.Content(image)" height="60" width="100" onclick="currentSlide(@number)" />*@
            <div class="dot" style="height: 60px; width: 100px;" onclick="currentSlide(@number)">
                <img style="width:auto; height:100%; object-fit:cover;" class=" mb-2" src="@Url.Content(image)"  />
                @{number++;}
            </div>
            //<span class="dot" onclick="currentSlide(@(i+1))" style="background:url(image)"></span>
        }

    </div>
    <hr />

    <div class="jumbotron">
