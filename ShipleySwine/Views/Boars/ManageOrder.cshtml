@model  ShipleySwine.ViewModels.BreedViewModel
@{
    ViewBag.Title = "ManageOrder";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="row">
        <div class="col-3 backgroundcolor">

            <table class="table table-bordered table-hover">
                <thead>
                    <tr class="text-center">
                        <th>Breed</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var item in Model.breeds)
                    {
                        <tr class="text-center">

                            <td>@item</td>
                            <td class="text-center">
                                <a style="width: 100px;" class=" btn btn-warning" href="@Url.Action("EditOrder","Boars", new { breed = item})"><i class="fa fa-pencil"> Edit</i></a>
                                @*<a style="width: 100px;" class=" btn btn-danger" href="@Url.Action("Delete","Boars", new { id = item.Key})"><i class="fa fa-trash"> Delete</i></a>*@
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
        <div class="col-9 backgroundcolor">
            @*<table class="table table-bordered table-hover bg-white">
                    <thead>
                        <tr class="text-center">
                            <th>Breed</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="text-center">
                                <td>@item.Breed</td>
                                <td class="text-center">
                                    <a style="width: 100px;" class=" btn btn-warning" href="@Url.Action("Edit","Boars", new { id = item.Breed})"><i class="fa fa-pencil"> Edit</i></a>
                                    <a style="width: 100px;" class=" btn btn-danger" href="@Url.Action("Delete","Boars", new { id = item.Breed})"><i class="fa fa-trash"> Delete</i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>*@
        </div>
    </div>
</div>


