
@{
    ViewBag.Title = "getBannerForm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

    <div class="container backgroundcolor">
        @using (Html.BeginForm("getBannerForm", "Admin"))
        {
            <div class="form-group">
                <label class="control-label">Banner Text</label>
                <input class="form-control" type="text" name="newBannerText" value="@ViewBag.bannerText" />
            </div>
            <div class="form-group">
                <input class="btn btn-primary" type="submit" value="Save" />
            </div>
            if (ViewBag.submitText != null || ViewBag.submitText == "Save Successful")
            {
                <p class="text-success">@ViewBag.submitText</p>
            }
            else
            {
                <p class="text-danger">@ViewBag.submitText</p>
            }

        }
    </div>

